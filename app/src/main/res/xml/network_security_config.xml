<?xml version="1.0" encoding="utf-8"?>
<network-security-config xmlns:tools="http://schemas.android.com/tools">
    <!--
      A modern web browser must be able to load the open web, including the
      tail of HTTP-only legacy sites (school portals, intranet OAuth servers,
      old captive-portal pages). The address bar reflects whether the active
      page is HTTPS so the user can see when a page is insecure. Lint flags
      this as InsecureBaseConfiguration; that's accurate but expected for a
      browser.
    -->
    <base-config cleartextTrafficPermitted="true" tools:ignore="InsecureBaseConfiguration">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
