<?xml version="1.0" encoding="utf-8"?>
<!--
  Form for configuring a user-supplied search engine. Three fields:

    * Display name — what shows in Settings + the address bar caption.
    * Search URL template — must include `%s` where the query goes.
    * Home URL (optional) — what the "Home" button navigates to when
      this engine is active.

  Validation lives in SettingsActivity.isPlausibleSearchTemplate.
-->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingStart="20dp"
    android:paddingTop="12dp"
    android:paddingEnd="20dp"
    android:paddingBottom="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="4dp"
            android:text="@string/setting_custom_search_name_label"
            android:textColor="@color/browser_text"
            android:textSize="13sp" />

        <EditText
            android:id="@+id/custom_search_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/setting_custom_search_name_hint"
            android:importantForAutofill="no"
            android:inputType="textCapWords"
            android:maxLines="1"
            android:textColor="@color/browser_text"
            android:textColorHint="@color/browser_hint" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="14dp"
            android:paddingBottom="4dp"
            android:text="@string/setting_custom_search_url_label"
            android:textColor="@color/browser_text"
            android:textSize="13sp" />

        <EditText
            android:id="@+id/custom_search_url"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/setting_custom_search_url_hint"
            android:importantForAutofill="no"
            android:inputType="textUri"
            android:maxLines="1"
            android:textColor="@color/browser_text"
            android:textColorHint="@color/browser_hint" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="4dp"
            android:paddingBottom="14dp"
            android:text="@string/setting_custom_search_url_helper"
            android:textColor="@color/browser_hint"
            android:textSize="12sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="4dp"
            android:text="@string/setting_custom_search_home_label"
            android:textColor="@color/browser_text"
            android:textSize="13sp" />

        <EditText
            android:id="@+id/custom_search_home"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/setting_custom_search_home_hint"
            android:importantForAutofill="no"
            android:inputType="textUri"
            android:maxLines="1"
            android:textColor="@color/browser_text"
            android:textColorHint="@color/browser_hint" />
    </LinearLayout>
</ScrollView>
