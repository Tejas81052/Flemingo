<?xml version="1.0" encoding="utf-8"?>
<!--
  activity_no_internet.xml — animated offline screen.

  Surfaced by MainActivity when ConnectivityManager reports the active
  network is unavailable (or when WebView.onReceivedError fires with
  ERR_INTERNET_DISCONNECTED). The layout is self-contained — no special
  Activity is needed, but the spinning refresh icon inside the stamp
  button needs the small ValueAnimator from
  handoff/NoInternetActivity.patch.kt.

  IDs:
    no_internet_root         FrameLayout root
    no_internet_tab_url      TextView showing the URL we failed to reach
    no_internet_close        ImageButton (close current tab)
    no_internet_hero         ImageView holding the AVD
    no_internet_try_again    Button (stamp)
    no_internet_refresh_icon ImageView inside the stamp — the
                             ValueAnimator drives its rotation
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/no_internet_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/browser_bg_solid"
    android:clickable="true"
    android:focusable="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingTop="24dp"
        android:paddingEnd="24dp"
        android:paddingBottom="32dp">

        <!-- The failed URL already shows in the app's real address bar
             above this overlay, so the offline screen no longer repeats
             it in a pill. The reclaimed space goes to the hero + copy. -->

        <!-- Hero: AnimatedVectorDrawable.
             Started/stopped from NoInternetController. -->
        <ImageView
            android:id="@+id/no_internet_hero"
            android:layout_width="match_parent"
            android:layout_height="252dp"
            android:layout_marginTop="12dp"
            android:contentDescription="@null"
            android:src="@drawable/avd_no_internet_hero" />

        <!-- Copy block -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:fontFamily="monospace"
            android:letterSpacing="0.18"
            android:text="@string/no_internet_eyebrow"
            android:textAllCaps="true"
            android:textColor="@color/browser_accent"
            android:textSize="11sp"
            android:textStyle="bold"
            tools:text="OFFLINE" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:fontFamily="serif"
            android:lineSpacingMultiplier="1.12"
            android:text="@string/no_internet_title"
            android:textColor="@color/browser_text"
            android:textSize="34sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="8dp"
            android:fontFamily="serif"
            android:lineSpacingExtra="6dp"
            android:text="@string/no_internet_body"
            android:textColor="@color/browser_text_2"
            android:textSize="15sp"
            android:textStyle="italic" />

        <Space
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- Stamp button.
             FrameLayout host so we can stack the vector background +
             the label/icon on top with their own layouts. The whole
             thing is clickable via the outer Button. Side margins narrow
             it slightly (more stamp-like, less full-width bar); the gap
             above it comes from the weighted Space, widened by the
             trimmed hero height. -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:layout_marginStart="12dp"
            android:layout_marginTop="12dp"
            android:layout_marginEnd="12dp"
            android:layout_marginBottom="4dp">

            <Button
                android:id="@+id/no_internet_try_again"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_no_internet_stamp"
                android:contentDescription="@string/no_internet_try_again_cd"
                android:text=""
                android:textAllCaps="false" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clickable="false"
                android:duplicateParentState="true"
                android:focusable="false"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="24dp"
                android:paddingEnd="24dp">

                <!-- Refresh icon in a thin square — its rotation is
                     driven by a ValueAnimator (see Kotlin patch). -->
                <FrameLayout
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="@drawable/bg_no_internet_stamp_chip"
                    android:duplicateParentState="true">

                    <ImageView
                        android:id="@+id/no_internet_refresh_icon"
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:layout_gravity="center"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_refresh_24"
                        app:tint="@color/browser_on_accent" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="14dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:alpha="0.85"
                        android:fontFamily="monospace"
                        android:letterSpacing="0.18"
                        android:text="@string/no_internet_stamp_eyebrow"
                        android:textAllCaps="true"
                        android:textColor="@color/browser_on_accent"
                        android:textSize="9sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:fontFamily="serif"
                        android:text="@string/no_internet_try_again"
                        android:textColor="@color/browser_on_accent"
                        android:textSize="24sp"
                        android:textStyle="italic" />
                </LinearLayout>
            </LinearLayout>
        </FrameLayout>

    </LinearLayout>

</FrameLayout>
