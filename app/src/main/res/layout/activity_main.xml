<?xml version="1.0" encoding="utf-8"?>
<!--
  Root is a CoordinatorLayout so the top chrome (address bar + progress)
  can auto-hide via AppBarLayout scroll flags. The main content and
  bottom chrome are hosted in a vertical LinearLayout (content_wrapper)
  that shifts up when the top bar hides.
-->
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/browser_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/top_chrome"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/browser_bg_solid"
        app:elevation="0dp"
        app:liftOnScroll="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingTop="8dp"
            android:paddingEnd="12dp"
            android:paddingBottom="6dp">

            <!--
              V9: refresh button (right side) coexists with the address
              bar pill. The pill is `0dp` + `layout_weight="1"` so it
              still stretches to fill all leftover space; the refresh
              button takes its natural 44dp on the trailing edge.
            -->
            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:background="@drawable/bg_address_pill">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="14dp"
                    android:paddingEnd="6dp">

                    <ImageView
                        android:id="@+id/security_indicator"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:contentDescription="@string/security_indicator_secure"
                        android:src="@drawable/ic_lock_24"
                        app:tint="@color/browser_hint" />

                    <me.thimmaiah.ebors.AddressEditText
                        android:id="@+id/address_bar"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@android:color/transparent"
                        android:fontFamily="monospace"
                        android:gravity="center_vertical"
                        android:hint="@string/address_hint"
                        android:imeOptions="actionGo"
                        android:importantForAutofill="no"
                        android:inputType="textUri"
                        android:letterSpacing="-0.01"
                        android:maxLines="1"
                        android:paddingStart="10dp"
                        android:paddingEnd="6dp"
                        android:textColor="@color/browser_text"
                        android:textColorHint="@color/browser_hint"
                        android:textSize="13sp" />

                    <ImageButton
                        android:id="@+id/go_button"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="@string/go_button"
                        android:padding="8dp"
                        android:src="@drawable/ic_arrow_forward_24"
                        app:tint="?attr/browserAccent" />
                </LinearLayout>
            </FrameLayout>

            <ImageButton
                android:id="@+id/qr_scan_button"
                android:layout_width="40dp"
                android:layout_height="44dp"
                android:layout_marginStart="2dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/qr_scan_button"
                android:padding="9dp"
                android:src="@drawable/ic_qr_scan_24"
                app:tint="@color/browser_text_2" />

            <ImageButton
                android:id="@+id/refresh_button"
                android:layout_width="40dp"
                android:layout_height="44dp"
                android:layout_marginStart="2dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/refresh_button"
                android:padding="10dp"
                android:src="@drawable/ic_refresh_24"
                app:tint="@color/browser_text_2" />
        </LinearLayout>

        <ProgressBar
            android:id="@+id/loading_progress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:max="100"
            android:progress="0"
            android:progressBackgroundTint="@android:color/transparent"
            android:progressTint="?attr/browserAccent"
            android:visibility="gone" />

        <!--
          Find-in-page bar stays pinned (no scroll flags) so a long
          search session isn't interrupted by the bar disappearing on
          scroll. Visibility is gone by default.
        -->
        <LinearLayout
            android:id="@+id/find_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/browser_surface_muted"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="14dp"
            android:paddingTop="6dp"
            android:paddingEnd="6dp"
            android:paddingBottom="6dp"
            android:visibility="gone">

            <EditText
                android:id="@+id/find_input"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:hint="@string/find_in_page_hint"
                android:imeOptions="actionSearch"
                android:importantForAutofill="no"
                android:inputType="text"
                android:maxLines="1"
                android:textColor="@color/browser_text"
                android:textColorHint="@color/browser_hint"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/find_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:textColor="@color/browser_hint"
                android:textSize="11sp"
                tools:text="2 / 14" />

            <ImageButton
                android:id="@+id/find_prev"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/find_previous"
                android:padding="10dp"
                android:src="@drawable/ic_chevron_up_24"
                app:tint="@color/browser_icon" />

            <ImageButton
                android:id="@+id/find_next"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/find_next"
                android:padding="10dp"
                android:src="@drawable/ic_chevron_down_24"
                app:tint="@color/browser_icon" />

            <ImageButton
                android:id="@+id/find_close"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/find_close"
                android:padding="10dp"
                android:src="@drawable/ic_close_24"
                app:tint="@color/browser_icon" />
        </LinearLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <!--
      Content Wrapper: Vertically stacks the main content area and
      the bottom chrome. By being a scrolling-view-behavior sibling of
      the AppBar, it ensures that the entire stack (including the
      bottom bar) never overlaps.
    -->
    <LinearLayout
        android:id="@+id/content_wrapper"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <!-- Host for WebView and overlays -->
        <FrameLayout
            android:id="@+id/main_content_area"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <!--
              Tab host.
            -->
            <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
                android:id="@+id/web_container"
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <FrameLayout
                    android:id="@+id/web_host"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent" />
            </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

            <!--
              v10 start page (about:home).
            -->
            <include
                android:id="@+id/start_page_overlay"
                layout="@layout/view_start_page"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="gone" />

            <!--
              v10 private start page.
            -->
            <include
                android:id="@+id/private_start_page_overlay"
                layout="@layout/view_start_page_private"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="gone" />

            <!--
              Animated offline screen. Shown over the WebView (chrome stays
              visible) when a main-frame load fails with no connectivity;
              cleared on retry / navigation / tab switch.
            -->
            <include
                android:id="@+id/no_internet_overlay"
                layout="@layout/activity_no_internet"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="gone" />

            <!--
              Animated site-not-found screen. Shown over the WebView (chrome
              stays visible) when an online main-frame load fails with a
              host-lookup (DNS) error; cleared on retry / navigation / tab
              switch. Mirrors the offline overlay placement and lifecycle.
            -->
            <include
                android:id="@+id/site_not_found_overlay"
                layout="@layout/activity_site_not_found"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="gone" />

            <!--
              v10 full-screen tab-switcher overlay.
            -->
            <LinearLayout
                android:id="@+id/tab_switcher_overlay"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@color/browser_bg_solid"
                android:orientation="vertical"
                android:visibility="gone">

                <!-- Title row: "N open tabs" + accent + button -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="20dp"
                    android:paddingTop="14dp"
                    android:paddingEnd="16dp"
                    android:paddingBottom="14dp">

                    <TextView
                        android:id="@+id/tab_switcher_title"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:fontFamily="serif"
                        android:textColor="@color/browser_text"
                        android:textSize="26sp"
                        android:textStyle="italic"
                        tools:text="4 open tabs" />

                    <ImageButton
                        android:id="@+id/tab_switcher_new"
                        android:layout_width="46dp"
                        android:layout_height="46dp"
                        android:background="@drawable/bg_new_tab_fab"
                        android:contentDescription="@string/tab_switcher_new_tab_button"
                        android:padding="11dp"
                        android:src="@drawable/ic_add_24"
                        app:tint="@color/browser_on_accent" />
                </LinearLayout>

                <!-- Regular / Private segmented filter -->
                <LinearLayout
                    android:id="@+id/tab_switcher_segments"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp"
                    android:background="@drawable/bg_segment_container"
                    android:orientation="horizontal"
                    android:padding="3dp">

                    <LinearLayout
                        android:id="@+id/tab_segment_regular"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@drawable/bg_segment_active"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/tab_segment_regular_label"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/tab_switcher_segment_regular"
                            android:textColor="@color/browser_text"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tab_segment_regular_count"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="6dp"
                            android:fontFamily="monospace"
                            android:textColor="@color/browser_hint"
                            android:textSize="11sp"
                            tools:text="4" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/tab_segment_private"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@android:color/transparent"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:orientation="horizontal">

                        <ImageView
                            android:id="@+id/tab_segment_private_icon"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_marginEnd="6dp"
                            android:importantForAccessibility="no"
                            android:src="@drawable/ic_incognito_24"
                            app:tint="@color/browser_text_2" />

                        <TextView
                            android:id="@+id/tab_segment_private_label"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/tab_switcher_segment_private"
                            android:textColor="@color/browser_text_2"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/tab_segment_private_count"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="6dp"
                            android:fontFamily="monospace"
                            android:textColor="@color/browser_hint"
                            android:textSize="11sp"
                            tools:text="2" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Tab grid (2 columns) -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/tab_switcher_list"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:clipToPadding="false"
                    android:nestedScrollingEnabled="false"
                    android:paddingStart="12dp"
                    android:paddingTop="14dp"
                    android:paddingEnd="12dp"
                    android:scrollbars="vertical" />

                <!-- Empty state (visible when the active segment has no tabs) -->
                <TextView
                    android:id="@+id/tab_switcher_empty"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:paddingStart="24dp"
                    android:paddingEnd="24dp"
                    android:textColor="@color/browser_hint"
                    android:textSize="14sp"
                    android:visibility="gone"
                    tools:text="@string/tab_switcher_empty_private" />
            </LinearLayout>
        </FrameLayout>

        <!--
          Bottom chrome group. Visibility toggled by MainActivity.kt on
          scroll.
        -->
        <LinearLayout
            android:id="@+id/bottom_chrome"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/browser_bg_solid"
            android:orientation="vertical">

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/browser_stroke" />

            <!--
              v10.1: bottom chrome compacted ~14dp to give the WebView
              more vertical real estate (matches Brave-style framing for
              YouTube Shorts and other video-first pages). Caption keeps
              its tracked letter-spacing so the marker still reads, but
              its padding and text size are tightened.
            -->
            <TextView
                android:id="@+id/browser_caption"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:gravity="center"
                android:letterSpacing="0.02"
                android:paddingStart="18dp"
                android:paddingTop="4dp"
                android:paddingEnd="18dp"
                android:paddingBottom="0dp"
                android:text="@string/browser_caption"
                android:textColor="@color/browser_hint"
                android:textSize="10sp"
                tools:text="Search engine: DuckDuckGo" />

            <!--
              V8: bottom nav redesign. Left → right:
                1. Bookmark    → opens the library (bookmarks/history)
                2. Tab switch  → outlined square with live tab-count overlay
                3. Search      → focuses the address bar so the user can type
                4. Home        → loads the configured home URL
                5. Menu (⋮)    → opens the browser PopupMenu
            -->
            <LinearLayout
                android:id="@+id/navigation_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="4dp"
                android:paddingTop="0dp"
                android:paddingEnd="4dp"
                android:paddingBottom="2dp">

                <ImageButton
                    android:id="@+id/bookmark_button"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/bookmark_button"
                    android:padding="12dp"
                    android:src="@drawable/ic_bookmark_outline_24"
                    app:tint="@color/browser_icon" />

                <!--
                  Tab-switcher button. The outlined square is the icon; the
                  live count is painted on top via tab_count_text. The whole
                  FrameLayout is the click target (clickable + focusable +
                  borderless ripple) so taps anywhere inside fire the
                  switcher.
                -->
                <FrameLayout
                    android:id="@+id/tabs_button"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true"
                    android:contentDescription="@string/tab_switcher_button"
                    android:focusable="true">

                    <ImageView
                        android:id="@+id/tabs_button_icon"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:importantForAccessibility="no"
                        android:padding="12dp"
                        android:src="@drawable/ic_tabs_outline_24"
                        app:tint="@color/browser_icon" />

                    <!--
                      v10.1: badge sits ON the icon's upper-right corner,
                      touching its boundary. With the compacted bottom
                      chrome the button is now 48dp and the icon's padding
                      is 12dp, so the icon occupies (12..36, 12..36).
                      Centring the 16x14 badge on the (36, 12) corner
                      gives 8dp end-margin + 9dp top-margin (badge bottom-
                      left lands flush against the icon edge).
                    -->
                    <TextView
                        android:id="@+id/tab_count_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="top|end"
                        android:layout_marginTop="9dp"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/bg_tab_badge"
                        android:fontFamily="monospace"
                        android:importantForAccessibility="no"
                        android:includeFontPadding="false"
                        android:paddingStart="4dp"
                        android:paddingEnd="4dp"
                        android:textColor="@color/browser_text"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        tools:text="2" />

                    <!--
                      Active-state indicator dot under the tabs icon. Painted
                      when the tab switcher overlay is open so the user can
                      tell at a glance which surface they're on. Visibility
                      toggled in MainActivity.setTabSwitcherActiveIndicator.
                    -->
                    <View
                        android:id="@+id/tabs_button_active_dot"
                        android:layout_width="5dp"
                        android:layout_height="5dp"
                        android:layout_gravity="center_horizontal|bottom"
                        android:layout_marginBottom="2dp"
                        android:background="@drawable/bg_tab_active_dot"
                        android:visibility="gone" />
                </FrameLayout>

                <ImageButton
                    android:id="@+id/search_button"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/search_button"
                    android:padding="12dp"
                    android:src="@drawable/ic_search_24"
                    app:tint="@color/browser_icon" />

                <ImageButton
                    android:id="@+id/home_button"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/home_button"
                    android:padding="12dp"
                    android:src="@drawable/ic_home_outline_24"
                    app:tint="@color/browser_icon" />

                <ImageButton
                    android:id="@+id/menu_button"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/browser_menu"
                    android:padding="12dp"
                    android:src="@drawable/ic_more_vert_24"
                    app:tint="@color/browser_icon" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
