<?xml version="1.0" encoding="utf-8"?>
<!--
  Settings → Appearance → Accent row. Stacks the title/summary text
  on top of a 5-swatch horizontal row. SettingsActivity wires the
  five swatch ImageViews up at runtime — they share an id so the
  activity can iterate them by index, mapping each to an
  AccentTheme value.
-->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    style="@style/SettingsRowCard">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingTop="14dp"
        android:paddingEnd="16dp"
        android:paddingBottom="16dp">

        <TextView
            style="@style/SettingsRowTitle"
            android:text="@string/setting_accent_title" />

        <TextView
            style="@style/SettingsRowSummary"
            android:text="@string/setting_accent_summary" />

        <LinearLayout
            android:id="@+id/accent_swatch_row"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:orientation="horizontal">

            <FrameLayout
                android:id="@+id/accent_swatch_0"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/bg_accent_swatch"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground">

                <ImageView
                    android:id="@+id/accent_swatch_check_0"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="center"
                    android:importantForAccessibility="no"
                    android:src="@drawable/ic_check_24"
                    android:visibility="gone"
                    app:tint="@color/white" />
            </FrameLayout>

            <FrameLayout
                android:id="@+id/accent_swatch_1"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_marginStart="10dp"
                android:background="@drawable/bg_accent_swatch"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground">

                <ImageView
                    android:id="@+id/accent_swatch_check_1"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="center"
                    android:importantForAccessibility="no"
                    android:src="@drawable/ic_check_24"
                    android:visibility="gone"
                    app:tint="@color/white" />
            </FrameLayout>

            <FrameLayout
                android:id="@+id/accent_swatch_2"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_marginStart="10dp"
                android:background="@drawable/bg_accent_swatch"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground">

                <ImageView
                    android:id="@+id/accent_swatch_check_2"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="center"
                    android:importantForAccessibility="no"
                    android:src="@drawable/ic_check_24"
                    android:visibility="gone"
                    app:tint="@color/white" />
            </FrameLayout>

            <FrameLayout
                android:id="@+id/accent_swatch_3"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_marginStart="10dp"
                android:background="@drawable/bg_accent_swatch"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground">

                <ImageView
                    android:id="@+id/accent_swatch_check_3"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="center"
                    android:importantForAccessibility="no"
                    android:src="@drawable/ic_check_24"
                    android:visibility="gone"
                    app:tint="@color/white" />
            </FrameLayout>

            <FrameLayout
                android:id="@+id/accent_swatch_4"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_marginStart="10dp"
                android:background="@drawable/bg_accent_swatch"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground">

                <ImageView
                    android:id="@+id/accent_swatch_check_4"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="center"
                    android:importantForAccessibility="no"
                    android:src="@drawable/ic_check_24"
                    android:visibility="gone"
                    app:tint="@color/white" />
            </FrameLayout>
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
