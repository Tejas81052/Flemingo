<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/welcome_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/browser_bg_solid">

    <ViewFlipper
        android:id="@+id/welcome_flipper"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:measureAllChildren="false"
        android:inAnimation="@android:anim/fade_in"
        android:outAnimation="@android:anim/fade_out">

        <!-- Page 1 — Welcome -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:minHeight="match_parent"
                android:orientation="vertical"
                android:paddingStart="28dp"
                android:paddingTop="40dp"
                android:paddingEnd="28dp"
                android:paddingBottom="32dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.08"
                    android:text="@string/welcome_eyebrow"
                    android:textAllCaps="true"
                    android:textColor="?attr/browserAccent"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="@string/welcome_title"
                    android:textColor="@color/browser_text"
                    android:textSize="28sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:lineSpacingExtra="3dp"
                    android:text="@string/welcome_subtitle"
                    android:textColor="@color/browser_text_2"
                    android:textSize="15sp" />

                <Space
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <Button
                    android:id="@+id/welcome_continue"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="32dp"
                    android:background="@drawable/bg_welcome_primary_button"
                    android:text="@string/welcome_continue"
                    android:textAllCaps="false"
                    android:textColor="@color/browser_on_accent"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/welcome_version"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:gravity="center"
                    android:textColor="@color/browser_hint"
                    android:textSize="11sp"
                    tools:text="Version 1.0" />

            </LinearLayout>
        </ScrollView>

        <!-- Page 2 — Privacy promise & terms acceptance -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="28dp"
                android:paddingTop="40dp"
                android:paddingEnd="28dp"
                android:paddingBottom="32dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.08"
                    android:text="@string/welcome_privacy_eyebrow"
                    android:textAllCaps="true"
                    android:textColor="?attr/browserAccent"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="@string/welcome_privacy_title"
                    android:textColor="@color/browser_text"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:lineSpacingExtra="5dp"
                    android:text="@string/welcome_privacy_bullets"
                    android:textColor="@color/browser_text"
                    android:textSize="14sp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="22dp"
                    android:background="@color/browser_stroke" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:orientation="horizontal">

                    <CheckBox
                        android:id="@+id/welcome_terms_check"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:buttonTint="?attr/browserAccent" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:layout_gravity="center_vertical"
                        android:lineSpacingExtra="3dp"
                        android:text="@string/welcome_terms_consent"
                        android:textColor="@color/browser_text"
                        android:textSize="14sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:layout_marginStart="34dp"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/welcome_privacy_link"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:clickable="true"
                        android:focusable="true"
                        android:padding="6dp"
                        android:text="@string/welcome_link_privacy"
                        android:textColor="?attr/browserAccent"
                        android:textSize="13sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:padding="6dp"
                        android:text="·"
                        android:textColor="@color/browser_hint"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/welcome_terms_link"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:clickable="true"
                        android:focusable="true"
                        android:padding="6dp"
                        android:text="@string/welcome_link_terms"
                        android:textColor="?attr/browserAccent"
                        android:textSize="13sp" />
                </LinearLayout>

                <Button
                    android:id="@+id/welcome_accept"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="28dp"
                    android:background="@drawable/bg_welcome_primary_button"
                    android:text="@string/welcome_accept"
                    android:textAllCaps="false"
                    android:textColor="@color/browser_on_accent"
                    android:textSize="15sp"
                    android:textStyle="bold" />

            </LinearLayout>
        </ScrollView>

        <!-- Page 3 — Default browser (optional) -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:minHeight="match_parent"
                android:orientation="vertical"
                android:paddingStart="28dp"
                android:paddingTop="40dp"
                android:paddingEnd="28dp"
                android:paddingBottom="32dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.08"
                    android:text="@string/welcome_default_eyebrow"
                    android:textAllCaps="true"
                    android:textColor="?attr/browserAccent"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="@string/welcome_default_title"
                    android:textColor="@color/browser_text"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:lineSpacingExtra="4dp"
                    android:text="@string/welcome_default_body"
                    android:textColor="@color/browser_text_2"
                    android:textSize="14sp" />

                <Space
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <Button
                    android:id="@+id/welcome_set_default"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="28dp"
                    android:background="@drawable/bg_welcome_primary_button"
                    android:text="@string/welcome_set_default"
                    android:textAllCaps="false"
                    android:textColor="@color/browser_on_accent"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/welcome_skip_default"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:padding="12dp"
                    android:text="@string/welcome_skip"
                    android:textColor="@color/browser_text_2"
                    android:textSize="14sp" />

            </LinearLayout>
        </ScrollView>

    </ViewFlipper>

</FrameLayout>
