<?xml version="1.0" encoding="utf-8"?>
<!--
  Hosted inside a BottomSheetDialog. Title row carries the live tab count
  and a "+" button that creates a new tab; the RecyclerView below it lists
  every tab in z-order with the active one visually marked. Height is left
  to the BottomSheetDialog's default behaviour (peeks at ~half the screen,
  fully expandable to ~the full screen by dragging up).
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingTop="8dp"
    android:paddingBottom="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingTop="8dp"
        android:paddingEnd="12dp"
        android:paddingBottom="8dp">

        <TextView
            android:id="@+id/tab_switcher_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/browser_text"
            android:textSize="16sp"
            android:textStyle="bold"
            tools:ignore="MissingDefaultResource"
            xmlns:tools="http://schemas.android.com/tools"
            tools:text="Tabs (3)" />

        <ImageButton
            android:id="@+id/tab_switcher_new"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/new_tab"
            android:padding="10dp"
            android:src="@drawable/ic_add_24"
            app:tint="?attr/browserAccent" />
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/tab_switcher_list"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:clipToPadding="false"
        android:paddingBottom="4dp" />
</LinearLayout>
