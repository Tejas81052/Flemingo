<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/licenses_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/browser_bg_solid"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/licenses_toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/browser_bg_solid"
        app:navigationIcon="@drawable/ic_arrow_back_24"
        app:title="@string/open_source_licenses_title"
        app:titleTextAppearance="@style/TextAppearance.Ebors.Title" />

    <WebView
        android:id="@+id/licenses_webview"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />
</LinearLayout>
