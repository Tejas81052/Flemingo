<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/settings_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/settings_toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@android:color/transparent"
        app:navigationIcon="@drawable/ic_arrow_back_24"
        app:title="@string/settings_title"
        app:titleTextAppearance="@style/TextAppearance.Ebors.Title"
        app:titleTextColor="@color/browser_text" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="14dp"
            android:paddingTop="6dp"
            android:paddingEnd="14dp"
            android:paddingBottom="32dp">

            <TextView
                style="@style/SettingsHeader"
                android:text="@string/settings_section_appearance" />

            <include
                android:id="@+id/row_desktop_mode"
                layout="@layout/item_settings_switch" />

            <include
                android:id="@+id/row_accent"
                layout="@layout/item_settings_accent" />

            <TextView
                style="@style/SettingsHeader"
                android:text="@string/settings_section_search" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/row_search_engine"
                style="@style/SettingsRowCard"
                android:foreground="?attr/selectableItemBackground">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="16dp"
                    android:paddingTop="14dp"
                    android:paddingEnd="16dp"
                    android:paddingBottom="14dp">

                    <TextView
                        style="@style/SettingsRowTitle"
                        android:text="@string/setting_search_engine_title" />

                    <TextView
                        android:id="@+id/search_engine_summary"
                        style="@style/SettingsRowSummary"
                        tools:text="DuckDuckGo" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                style="@style/SettingsHeader"
                android:text="@string/settings_section_privacy" />

            <include
                android:id="@+id/row_ad_block"
                layout="@layout/item_settings_switch" />

            <include
                android:id="@+id/row_site_block"
                layout="@layout/item_settings_switch" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/row_manage_blocked_sites"
                style="@style/SettingsRowCard"
                android:foreground="?attr/selectableItemBackground">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="16dp"
                    android:paddingTop="14dp"
                    android:paddingEnd="16dp"
                    android:paddingBottom="14dp">

                    <TextView
                        style="@style/SettingsRowTitle"
                        android:text="@string/setting_manage_blocked_sites_title" />

                    <TextView
                        style="@style/SettingsRowSummary"
                        android:text="@string/setting_manage_blocked_sites_summary" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Tap to check for a refreshed ad/tracker list now. Summary
                 line is populated at runtime with the current version +
                 last-checked time (SettingsActivity.refreshBlocklistRow). -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/row_blocklist_update"
                style="@style/SettingsRowCard"
                android:foreground="?attr/selectableItemBackground">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="16dp"
                    android:paddingTop="14dp"
                    android:paddingEnd="16dp"
                    android:paddingBottom="14dp">

                    <TextView
                        style="@style/SettingsRowTitle"
                        android:text="@string/setting_blocklist_update_title" />

                    <TextView
                        android:id="@+id/blocklist_update_summary"
                        style="@style/SettingsRowSummary"
                        tools:text="Version 1 · checked 2 hours ago" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <include
                android:id="@+id/row_blocklist_auto_update"
                layout="@layout/item_settings_switch" />

            <include
                android:id="@+id/row_third_party_cookies"
                layout="@layout/item_settings_switch" />

            <include
                android:id="@+id/row_always_https"
                layout="@layout/item_settings_switch" />

            <include
                android:id="@+id/row_allow_mixed_content"
                layout="@layout/item_settings_switch" />

            <include
                android:id="@+id/row_aggressive_anti_adblock"
                layout="@layout/item_settings_switch" />

            <include
                android:id="@+id/row_block_webrtc"
                layout="@layout/item_settings_switch" />

            <include
                android:id="@+id/row_trim_referrer"
                layout="@layout/item_settings_switch" />

            <include
                android:id="@+id/row_history"
                layout="@layout/item_settings_switch" />

            <include
                android:id="@+id/row_search_suggestions"
                layout="@layout/item_settings_switch" />

            <TextView
                style="@style/SettingsHeader"
                android:text="@string/settings_section_advanced" />

            <include
                android:id="@+id/row_javascript"
                layout="@layout/item_settings_switch" />

            <include
                android:id="@+id/row_block_popups"
                layout="@layout/item_settings_switch" />

            <include
                android:id="@+id/row_tab_sleeping"
                layout="@layout/item_settings_switch" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/row_notification_permission"
                style="@style/SettingsRowCard"
                android:foreground="?attr/selectableItemBackground">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="16dp"
                    android:paddingTop="14dp"
                    android:paddingEnd="16dp"
                    android:paddingBottom="14dp">

                    <TextView
                        style="@style/SettingsRowTitle"
                        android:text="@string/setting_notification_permission_title" />

                    <TextView
                        android:id="@+id/notification_permission_summary"
                        style="@style/SettingsRowSummary"
                        tools:text="Disabled. Tap to allow." />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <include
                android:id="@+id/row_clear_data_on_exit"
                layout="@layout/item_settings_switch" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/row_clear_data"
                style="@style/SettingsRowCard"
                android:foreground="?attr/selectableItemBackground">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="16dp"
                    android:paddingTop="14dp"
                    android:paddingEnd="16dp"
                    android:paddingBottom="14dp">

                    <TextView
                        style="@style/SettingsRowTitle"
                        android:text="@string/clear_browsing_data" />

                    <TextView
                        style="@style/SettingsRowSummary"
                        android:text="@string/setting_clear_browsing_data_summary" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                style="@style/SettingsHeader"
                android:text="@string/settings_section_about" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/row_about"
                style="@style/SettingsRowCard"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="16dp"
                    android:paddingTop="14dp"
                    android:paddingEnd="12dp"
                    android:paddingBottom="14dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            style="@style/SettingsRowTitle"
                            android:text="@string/about_app_title" />

                        <TextView
                            android:id="@+id/about_version"
                            style="@style/SettingsRowSummary"
                            tools:text="Version 1.0" />
                    </LinearLayout>

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_marginStart="8dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_chevron_right_24"
                        app:tint="@color/browser_hint" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </ScrollView>

</LinearLayout>
