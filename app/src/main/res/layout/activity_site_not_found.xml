<?xml version="1.0" encoding="utf-8"?>
<!--
  activity_site_not_found.xml — animated "address not found" screen.

  Distinct from activity_no_internet.xml: this is shown when the DEVICE
  IS online but the HOST doesn't resolve. Surfaced from
  WebViewClient.onReceivedError when the error code is ERROR_HOST_LOOKUP.

  IDs:
    site_not_found_root         FrameLayout root
    site_not_found_hero         ImageView holding the AVD
    site_not_found_body         TextView — body copy (host injected)
    site_not_found_back         Button — go back
    site_not_found_retry        Button — try again

  The animated hero needs (hero.drawable as Animatable).start()
  in the show() routine — see SiteNotFoundController.
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/site_not_found_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/browser_bg_solid">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingTop="24dp"
        android:paddingEnd="24dp"
        android:paddingBottom="32dp">

        <!-- Hero: AnimatedVectorDrawable (the lonely door). -->
        <ImageView
            android:id="@+id/site_not_found_hero"
            android:layout_width="match_parent"
            android:layout_height="300dp"
            android:layout_marginTop="6dp"
            android:contentDescription="@null"
            android:src="@drawable/avd_site_not_found_hero" />

        <!-- Copy block -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:fontFamily="monospace"
            android:letterSpacing="0.18"
            android:text="@string/site_not_found_eyebrow"
            android:textAllCaps="true"
            android:textColor="@color/browser_accent"
            android:textSize="11sp"
            android:textStyle="bold"
            tools:text="ADDRESS NOT FOUND" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:fontFamily="serif"
            android:lineSpacingMultiplier="1.02"
            android:text="@string/site_not_found_title"
            android:textColor="@color/browser_text"
            android:textSize="34sp" />

        <TextView
            android:id="@+id/site_not_found_body"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:lineSpacingExtra="4dp"
            android:textColor="@color/browser_text_2"
            android:textSize="14sp"
            tools:text="We couldn't find a site at thevrege.com. Check the spelling, or search for it instead." />

        <Space
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- Action row: back + retry -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/site_not_found_back"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:background="@drawable/bg_site_not_found_secondary"
                android:drawableStart="@drawable/ic_arrow_back_24"
                android:drawablePadding="8dp"
                android:drawableTint="@color/browser_text_2"
                android:gravity="center"
                android:text="@string/site_not_found_back"
                android:textAllCaps="false"
                android:textColor="@color/browser_text_2"
                android:textSize="13sp" />

            <Button
                android:id="@+id/site_not_found_retry"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:background="@drawable/bg_site_not_found_secondary"
                android:drawableStart="@drawable/ic_refresh_24"
                android:drawablePadding="8dp"
                android:drawableTint="@color/browser_text_2"
                android:gravity="center"
                android:text="@string/site_not_found_retry"
                android:textAllCaps="false"
                android:textColor="@color/browser_text_2"
                android:textSize="13sp" />
        </LinearLayout>

    </LinearLayout>

</FrameLayout>
