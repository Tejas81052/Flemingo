<?xml version="1.0" encoding="utf-8"?>
<!--
  AnimatedVectorDrawable wrapping ill_no_internet_hero.

  How it composes:
    - <target android:name=…> selects a <group> or <path> from the
      VectorDrawable by name.
    - <aapt:attr name="android:animation"> attaches one or more
      ObjectAnimators / AnimatorSets to that target.

  Animations:
    grp_compass     → rotation 0→360, 60 000 ms, repeat infinite
    grp_pin         → translateY 0→-3→0, 3400 ms (set of two animators)
    grp_arc_{1..3}  → fillAlpha & strokeAlpha pulse, 3 000 ms, staggered
    path_flight     → trimPathOffset 0→0.25, 1 600 ms, linear, infinite
    grp_plane_push  → translateX, translateY, rotation choreography,
                       4 600 ms, infinite — the "push and bounce" beat
    grp_ripple_1/2/3 → scaleX/scaleY 0.2→2.2 + alpha 0.55→0, 2 600 ms,
                       staggered 0/900/1800 ms
    grp_specks_*    → translateY 0→-300, 7/8/9 s, infinite

  Start it from Kotlin:
    val avd = no_internet_hero.drawable as AnimatedVectorDrawable
    avd.start()
  Or use AnimatedVectorDrawableCompat for backwards compatibility.
-->
<animated-vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:drawable="@drawable/ill_no_internet_hero">

    <!-- Compass: slow continuous rotation -->
    <target android:name="grp_compass">
        <aapt:attr name="android:animation">
            <objectAnimator
                android:propertyName="rotation"
                android:duration="60000"
                android:valueFrom="0"
                android:valueTo="360"
                android:interpolator="@android:interpolator/linear"
                android:repeatCount="infinite" />
        </aapt:attr>
    </target>

    <!-- Destination pin bob -->
    <target android:name="grp_pin">
        <aapt:attr name="android:animation">
            <objectAnimator
                android:propertyName="translateY"
                android:duration="3400"
                android:valueFrom="0"
                android:valueTo="-3"
                android:repeatCount="infinite"
                android:repeatMode="reverse"
                android:interpolator="@android:interpolator/fast_out_slow_in" />
        </aapt:attr>
    </target>

    <!-- Wifi arc 1 (innermost) alpha pulse -->
    <target android:name="grp_arc_1">
        <aapt:attr name="android:animation">
            <objectAnimator
                android:propertyName="alpha"
                android:duration="3000"
                android:valueFrom="0.15"
                android:valueTo="0.55"
                android:repeatCount="infinite"
                android:repeatMode="reverse"
                android:interpolator="@android:interpolator/fast_out_slow_in" />
        </aapt:attr>
    </target>

    <!-- Arc 2 alpha pulse, staggered 500ms -->
    <target android:name="grp_arc_2">
        <aapt:attr name="android:animation">
            <objectAnimator
                android:propertyName="alpha"
                android:duration="3000"
                android:startOffset="500"
                android:valueFrom="0.15"
                android:valueTo="0.55"
                android:repeatCount="infinite"
                android:repeatMode="reverse"
                android:interpolator="@android:interpolator/fast_out_slow_in" />
        </aapt:attr>
    </target>

    <!-- Arc 3 (outermost) alpha pulse, staggered 1000ms -->
    <target android:name="grp_arc_3">
        <aapt:attr name="android:animation">
            <objectAnimator
                android:propertyName="alpha"
                android:duration="3000"
                android:startOffset="1000"
                android:valueFrom="0.15"
                android:valueTo="0.55"
                android:repeatCount="infinite"
                android:repeatMode="reverse"
                android:interpolator="@android:interpolator/fast_out_slow_in" />
        </aapt:attr>
    </target>

    <!-- Flight path crawl: trimPathOffset cycles 0→0.25.
         Combined with strokeDashArray on the path (set in code or via
         pathData with implicit gaps), this makes the dashes appear to
         move forward. -->
    <target android:name="path_flight">
        <aapt:attr name="android:animation">
            <objectAnimator
                android:propertyName="trimPathOffset"
                android:duration="1600"
                android:valueFrom="0"
                android:valueTo="0.25"
                android:repeatCount="infinite"
                android:interpolator="@android:interpolator/linear" />
        </aapt:attr>
    </target>

    <!-- Plane push: composed of translateX, translateY, rotation
         each animating across the 4.6s cycle with the same keyframes
         as the CSS version of the prototype. -->
    <target android:name="grp_plane_push">
        <aapt:attr name="android:animation">
            <set xmlns:android="http://schemas.android.com/apk/res/android"
                android:ordering="together">

                <objectAnimator
                    android:propertyName="translateX"
                    android:duration="4600"
                    android:repeatCount="infinite"
                    android:interpolator="@android:interpolator/fast_out_slow_in">
                    <propertyValuesHolder
                        android:propertyName="translateX"
                        android:valueType="floatType">
                        <keyframe android:fraction="0"    android:value="-14" android:interpolator="@android:interpolator/linear"/>
                        <keyframe android:fraction="0.32" android:value="4"   android:interpolator="@android:interpolator/linear"/>
                        <keyframe android:fraction="0.38" android:value="6"   android:interpolator="@android:interpolator/linear"/>
                        <keyframe android:fraction="0.52" android:value="-10" android:interpolator="@android:interpolator/linear"/>
                        <keyframe android:fraction="1"    android:value="-14" android:interpolator="@android:interpolator/linear"/>
                    </propertyValuesHolder>
                </objectAnimator>

                <objectAnimator
                    android:propertyName="translateY"
                    android:duration="4600"
                    android:repeatCount="infinite"
                    android:interpolator="@android:interpolator/fast_out_slow_in">
                    <propertyValuesHolder
                        android:propertyName="translateY"
                        android:valueType="floatType">
                        <keyframe android:fraction="0"    android:value="8"  android:interpolator="@android:interpolator/linear"/>
                        <keyframe android:fraction="0.32" android:value="-2" android:interpolator="@android:interpolator/linear"/>
                        <keyframe android:fraction="0.52" android:value="5"  android:interpolator="@android:interpolator/linear"/>
                        <keyframe android:fraction="1"    android:value="8"  android:interpolator="@android:interpolator/linear"/>
                    </propertyValuesHolder>
                </objectAnimator>

                <objectAnimator
                    android:propertyName="rotation"
                    android:duration="4600"
                    android:repeatCount="infinite"
                    android:interpolator="@android:interpolator/fast_out_slow_in">
                    <propertyValuesHolder
                        android:propertyName="rotation"
                        android:valueType="floatType">
                        <keyframe android:fraction="0"    android:value="-14" android:interpolator="@android:interpolator/linear"/>
                        <keyframe android:fraction="0.32" android:value="2"   android:interpolator="@android:interpolator/linear"/>
                        <keyframe android:fraction="0.38" android:value="8"   android:interpolator="@android:interpolator/linear"/>
                        <keyframe android:fraction="0.52" android:value="-22" android:interpolator="@android:interpolator/linear"/>
                        <keyframe android:fraction="1"    android:value="-14" android:interpolator="@android:interpolator/linear"/>
                    </propertyValuesHolder>
                </objectAnimator>
            </set>
        </aapt:attr>
    </target>

    <!-- Plane bob (layered on the push) -->
    <target android:name="grp_plane_bob">
        <aapt:attr name="android:animation">
            <objectAnimator
                android:propertyName="translateY"
                android:duration="2800"
                android:valueFrom="0"
                android:valueTo="-3"
                android:repeatCount="infinite"
                android:repeatMode="reverse"
                android:interpolator="@android:interpolator/fast_out_slow_in" />
        </aapt:attr>
    </target>

    <!-- Sonar ripples: scale + alpha, staggered start offsets -->
    <target android:name="grp_ripple_1">
        <aapt:attr name="android:animation">
            <set xmlns:android="http://schemas.android.com/apk/res/android"
                android:ordering="together">
                <objectAnimator
                    android:propertyName="scaleX"
                    android:duration="2600"
                    android:valueFrom="0.2"
                    android:valueTo="2.2"
                    android:repeatCount="infinite"
                    android:interpolator="@android:interpolator/decelerate_quint" />
                <objectAnimator
                    android:propertyName="scaleY"
                    android:duration="2600"
                    android:valueFrom="0.2"
                    android:valueTo="2.2"
                    android:repeatCount="infinite"
                    android:interpolator="@android:interpolator/decelerate_quint" />
                <objectAnimator
                    android:propertyName="alpha"
                    android:duration="2600"
                    android:valueFrom="0.55"
                    android:valueTo="0"
                    android:repeatCount="infinite"
                    android:interpolator="@android:interpolator/decelerate_quint" />
            </set>
        </aapt:attr>
    </target>

    <target android:name="grp_ripple_2">
        <aapt:attr name="android:animation">
            <set xmlns:android="http://schemas.android.com/apk/res/android"
                android:ordering="together">
                <objectAnimator
                    android:propertyName="scaleX"
                    android:duration="2600"
                    android:startOffset="900"
                    android:valueFrom="0.2"
                    android:valueTo="2.2"
                    android:repeatCount="infinite"
                    android:interpolator="@android:interpolator/decelerate_quint" />
                <objectAnimator
                    android:propertyName="scaleY"
                    android:duration="2600"
                    android:startOffset="900"
                    android:valueFrom="0.2"
                    android:valueTo="2.2"
                    android:repeatCount="infinite"
                    android:interpolator="@android:interpolator/decelerate_quint" />
                <objectAnimator
                    android:propertyName="alpha"
                    android:duration="2600"
                    android:startOffset="900"
                    android:valueFrom="0.55"
                    android:valueTo="0"
                    android:repeatCount="infinite"
                    android:interpolator="@android:interpolator/decelerate_quint" />
            </set>
        </aapt:attr>
    </target>

    <target android:name="grp_ripple_3">
        <aapt:attr name="android:animation">
            <set xmlns:android="http://schemas.android.com/apk/res/android"
                android:ordering="together">
                <objectAnimator
                    android:propertyName="scaleX"
                    android:duration="2600"
                    android:startOffset="1800"
                    android:valueFrom="0.2"
                    android:valueTo="2.2"
                    android:repeatCount="infinite"
                    android:interpolator="@android:interpolator/decelerate_quint" />
                <objectAnimator
                    android:propertyName="scaleY"
                    android:duration="2600"
                    android:startOffset="1800"
                    android:valueFrom="0.2"
                    android:valueTo="2.2"
                    android:repeatCount="infinite"
                    android:interpolator="@android:interpolator/decelerate_quint" />
                <objectAnimator
                    android:propertyName="alpha"
                    android:duration="2600"
                    android:startOffset="1800"
                    android:valueFrom="0.55"
                    android:valueTo="0"
                    android:repeatCount="infinite"
                    android:interpolator="@android:interpolator/decelerate_quint" />
            </set>
        </aapt:attr>
    </target>

    <!-- Specks: three tracks drifting up at different speeds -->
    <target android:name="grp_specks_1">
        <aapt:attr name="android:animation">
            <objectAnimator
                android:propertyName="translateY"
                android:duration="7000"
                android:valueFrom="0"
                android:valueTo="-310"
                android:repeatCount="infinite"
                android:interpolator="@android:interpolator/linear" />
        </aapt:attr>
    </target>

    <target android:name="grp_specks_2">
        <aapt:attr name="android:animation">
            <objectAnimator
                android:propertyName="translateY"
                android:duration="8500"
                android:valueFrom="0"
                android:valueTo="-310"
                android:repeatCount="infinite"
                android:interpolator="@android:interpolator/linear" />
        </aapt:attr>
    </target>

    <target android:name="grp_specks_3">
        <aapt:attr name="android:animation">
            <objectAnimator
                android:propertyName="translateY"
                android:duration="9500"
                android:valueFrom="0"
                android:valueTo="-310"
                android:repeatCount="infinite"
                android:interpolator="@android:interpolator/linear" />
        </aapt:attr>
    </target>

</animated-vector>
