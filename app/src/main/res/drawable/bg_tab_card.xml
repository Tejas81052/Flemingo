<?xml version="1.0" encoding="utf-8"?>
<!--
  Regular tab card outer shape. Paper surface fill + 1dp warm stroke,
  14dp radius matches the v10 menu tile. Private tabs use
  bg_tab_card_private.xml instead — that one stays ink-coloured
  regardless of theme.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="@color/browser_surface" />
    <stroke
        android:width="1dp"
        android:color="@color/browser_stroke" />
    <corners android:radius="14dp" />
</shape>
