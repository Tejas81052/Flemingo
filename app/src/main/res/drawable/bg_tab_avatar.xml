<?xml version="1.0" encoding="utf-8"?>
<!--
  Base shape for the per-tab favicon-letter avatar. TabSwitcherView
  tints this at bind time using the hashed AvatarPalette colour, so
  the fill defined here is just a fallback for the Layout Editor.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="@color/avatar_ink" />
    <corners android:radius="4dp" />
</shape>
