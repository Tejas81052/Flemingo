<?xml version="1.0" encoding="utf-8"?>
<!--
  Search pill on the start page. Same recipe as the address-bar pill
  (surface + 1dp warm stroke) but larger radius (24dp) so the pill
  reads as the primary CTA on the page.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="@color/browser_surface" />
    <stroke
        android:width="1dp"
        android:color="@color/browser_stroke" />
    <corners android:radius="24dp" />
</shape>
