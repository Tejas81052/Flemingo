<?xml version="1.0" encoding="utf-8"?>
<!--
  Themed background for plain EditText inputs used inside MaterialAlertDialog.
  Uses the same surface/stroke palette as the rest of the app so the text
  colour (browser_text) is readable in both light and dark mode.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="@color/browser_surface_muted" />
    <stroke
        android:width="1dp"
        android:color="@color/browser_stroke" />
    <corners android:radius="12dp" />
</shape>
