<?xml version="1.0" encoding="utf-8"?>
<!--
  Inner thumbnail box for a regular tab card. We don't currently
  capture page screenshots, so the box holds skeleton lines as a
  visual placeholder. Slight inset from the outer stroke so a tinted
  edge is visible inside the card.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="@color/browser_surface_muted" />
    <corners android:radius="10dp" />
</shape>
