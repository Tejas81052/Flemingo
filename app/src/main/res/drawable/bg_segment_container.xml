<?xml version="1.0" encoding="utf-8"?>
<!--
  Pill container behind the Regular/Private segmented control.
  Surface_muted fill + matching stroke so the active inner pill (which
  paints on top in surface paper) reads cleanly against it.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="@color/browser_surface_muted" />
    <stroke
        android:width="1dp"
        android:color="@color/browser_stroke" />
    <corners android:radius="14dp" />
</shape>
