<?xml version="1.0" encoding="utf-8"?>
<!--
  Tiny "DDG" badge inside the private search pill. Ink stroke so it
  doesn't pop against the ink pill background — it's meant to be
  spotted, not shouted.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="@android:color/transparent" />
    <stroke
        android:width="1dp"
        android:color="@color/tab_private_stroke" />
    <corners android:radius="6dp" />
</shape>
