<?xml version="1.0" encoding="utf-8"?>
<!--
  "This tab promises" card on the private start page. Subtle ink
  surface + warm ink stroke so it reads as a quiet info card on
  the page's near-black background.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="@color/tab_private_surface" />
    <stroke
        android:width="1dp"
        android:color="@color/tab_private_stroke" />
    <corners android:radius="14dp" />
</shape>
