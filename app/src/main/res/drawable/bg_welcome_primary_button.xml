<?xml version="1.0" encoding="utf-8"?>
<!--
    Pill-shaped accent button used by the welcome / onboarding screens.
    Same height as the rest of the chrome's primary actions; corner
    radius is half the height so it stays a true pill regardless of
    density bucket.

    The disabled state (used on the "Accept & continue" button before
    the terms checkbox is ticked) is a 35% tinted version of the
    accent so the affordance reads as "not yet" rather than "broken".
-->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_enabled="false">
        <shape android:shape="rectangle">
            <solid android:color="?attr/browserAccentSoft" />
            <corners android:radius="26dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="?attr/browserAccent" />
            <corners android:radius="26dp" />
        </shape>
    </item>
</selector>
