<?xml version="1.0" encoding="utf-8"?>
<!--
  One pinned-shortcut tile on the start page. Same warm stroke +
  surface fill as the menu tile but slightly smaller radius so a 4-
  column row reads as a row of buttons rather than pills.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="@color/browser_surface" />
    <stroke
        android:width="1dp"
        android:color="@color/browser_stroke" />
    <corners android:radius="12dp" />
</shape>
