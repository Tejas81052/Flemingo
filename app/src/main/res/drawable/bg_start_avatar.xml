<?xml version="1.0" encoding="utf-8"?>
<!--
  Letter-avatar shape used for both Pinned tiles (44dp) and Continue
  reading rows (28dp). Tinted at bind time from the hashed avatar
  palette so the fill colour declared here is just a Layout-Editor
  fallback.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="@color/avatar_ink" />
    <corners android:radius="8dp" />
</shape>
