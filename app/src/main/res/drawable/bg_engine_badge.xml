<?xml version="1.0" encoding="utf-8"?>
<!--
  Tiny "DDG" / "Google" badge inside the start-page search pill,
  showing which engine the typed query will route to. Transparent
  fill, hint-coloured outline.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="@android:color/transparent" />
    <stroke
        android:width="1dp"
        android:color="@color/browser_stroke" />
    <corners android:radius="6dp" />
</shape>
