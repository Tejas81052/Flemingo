<?xml version="1.0" encoding="utf-8"?>
<!--
  Skeleton line for private tabs (unused in current layout but kept
  so a future private-thumbnail-with-skeleton variant doesn't need a
  new resource). Tinted to read on the ink thumbnail body.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="@color/tab_private_stroke" />
    <corners android:radius="3dp" />
</shape>
