<?xml version="1.0" encoding="utf-8"?>
<!--
  One "Quick to" tile on the private start page. Mirrors
  bg_start_pinned_tile structurally but stays ink so private mode's
  visual identity is preserved.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="@color/tab_private_surface" />
    <stroke
        android:width="1dp"
        android:color="@color/tab_private_stroke" />
    <corners android:radius="12dp" />
</shape>
