<?xml version="1.0" encoding="utf-8"?>
<!--
  Round-square holder for the shield icon at the leading edge of the
  trackers-blocked card. Solid accent fill so the shield reads as a
  branded protection mark.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="?attr/browserAccent" />
    <corners android:radius="10dp" />
</shape>
