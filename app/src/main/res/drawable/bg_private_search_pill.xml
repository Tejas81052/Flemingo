<?xml version="1.0" encoding="utf-8"?>
<!--
  Search pill on the private start page. Same dimensions as the
  regular start-page pill but painted in ink so the whole private
  surface reads as a single mode.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="@color/tab_private_surface" />
    <stroke
        android:width="1dp"
        android:color="@color/tab_private_stroke" />
    <corners android:radius="24dp" />
</shape>
