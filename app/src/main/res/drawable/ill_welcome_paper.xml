<?xml version="1.0" encoding="utf-8"?>
<!--
  Welcome hero — "paper composition".
  Three layered sheets + a folded-corner page revealing terracotta,
  plus a few accent specks for visual joy. 320x240 viewport.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="320dp"
    android:height="240dp"
    android:viewportWidth="320"
    android:viewportHeight="240">

    <!-- Back paper (tilted, accent-soft tint) -->
    <group
        android:pivotX="160"
        android:pivotY="130"
        android:rotation="-7">
        <path
            android:fillColor="#F2DDD2"
            android:strokeColor="#9D3D27"
            android:strokeAlpha="0.7"
            android:strokeWidth="1.5"
            android:pathData="M62,44 L258,44 L258,216 L62,216 Z" />
    </group>

    <!-- Middle paper (slightly tilted, with hint lines) -->
    <group
        android:pivotX="160"
        android:pivotY="130"
        android:rotation="4">
        <path
            android:fillColor="#EFE9DC"
            android:strokeColor="#E2DBC8"
            android:strokeWidth="1.5"
            android:pathData="M56,40 L256,40 L256,212 L56,212 Z" />
        <path
            android:strokeColor="#D6CCB6"
            android:strokeWidth="3"
            android:strokeLineCap="round"
            android:pathData="M76,76 L220,76 M76,92 L200,92 M76,108 L168,108" />
    </group>

    <!-- Front page (with folded-out corner) -->
    <path
        android:fillColor="#FBF8F1"
        android:strokeColor="#2A241D"
        android:strokeWidth="2"
        android:strokeLineJoin="round"
        android:pathData="M60,56 L220,56 L252,88 L252,200 L60,200 Z" />

    <!-- Folded-corner reveal (terracotta) -->
    <path
        android:fillColor="#C8533A"
        android:pathData="M220,56 L252,88 L220,88 Z" />

    <!-- Article hint: italic word + body lines -->
    <group>
        <path
            android:strokeColor="#D6CCB6"
            android:strokeWidth="3"
            android:strokeLineCap="round"
            android:pathData="M78,124 L232,124 M78,138 L220,138 M78,152 L200,152 M78,174 L180,174" />
    </group>

    <!-- Bookmark ribbon hanging from the top -->
    <path
        android:fillColor="#C8533A"
        android:pathData="M188,56 L200,56 L200,110 L194,102 L188,110 Z" />

    <!-- Accent specks (small joy markers) -->
    <path
        android:fillColor="#C8533A"
        android:pathData="M280,44 m-4,0 a4,4 0 1,0 8,0 a4,4 0 1,0 -8,0 Z" />
    <path
        android:fillColor="#C8533A"
        android:pathData="M32,180 m-3,0 a3,3 0 1,0 6,0 a3,3 0 1,0 -6,0 Z" />
    <path
        android:fillColor="#C8533A"
        android:pathData="M284,172 m-2,0 a2,2 0 1,0 4,0 a2,2 0 1,0 -4,0 Z" />

    <!-- 4-point asterisk -->
    <path
        android:fillColor="#C8533A"
        android:pathData="M38,80 L42,72 L42,72 L42,88 L38,80 Z M30,80 L46,80 L30,80 Z" />
</vector>
