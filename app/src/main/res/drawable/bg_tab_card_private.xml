<?xml version="1.0" encoding="utf-8"?>
<!--
  Private tab card outer shape. Ink fill + ink stroke, same radius as
  the regular card. Deliberately theme-invariant: a private tab looks
  like a private tab in both light and dark mode.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="@color/tab_private_surface" />
    <stroke
        android:width="1dp"
        android:color="@color/tab_private_stroke" />
    <corners android:radius="14dp" />
</shape>
