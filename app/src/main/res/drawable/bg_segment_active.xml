<?xml version="1.0" encoding="utf-8"?>
<!--
  Active segment in the Regular/Private control. Paper surface +
  warm stroke + slightly tighter radius than the container so the
  pill nests cleanly with a hairline gap.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="@color/browser_surface" />
    <stroke
        android:width="1dp"
        android:color="@color/browser_stroke" />
    <corners android:radius="11dp" />
</shape>
