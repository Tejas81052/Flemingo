<?xml version="1.0" encoding="utf-8"?>
<!--
  Effective Browser v10 — "paper" palette.
  Migration from v9: hex values change but every color name is preserved
  so MainActivity.kt / layouts continue to compile without edits.

  Tokens were chosen via oklch so the warm paper hue is consistent across
  surface, stroke, and text without injecting saturation into neutrals.
  See res/values-night/colors.xml for the matching ink palette.
-->
<resources>
    <color name="white">#FFFFFFFF</color>

    <!-- Surfaces -->
    <color name="browser_bg_solid">#F6F2EA</color>       <!-- paper, the canvas behind chrome -->
    <color name="browser_surface">#FBF8F1</color>        <!-- address pill, cards, settings rows -->
    <color name="browser_surface_muted">#EFE9DC</color>  <!-- secondary surface, find bar -->
    <color name="browser_stroke">#E2DBC8</color>         <!-- hairlines on paper -->

    <!-- Accent (terracotta) -->
    <color name="browser_accent">#C8533A</color>
    <color name="browser_accent_soft">#F2DDD2</color>    <!-- accent at ~14% over paper, for tinted cards -->
    <color name="browser_on_accent">#FDFAF3</color>      <!-- text/icon on solid accent -->
    <color name="browser_chip_bg">#F2DDD2</color>        <!-- legacy alias, keeps existing refs working -->

    <!-- Ink (text + icons) -->
    <color name="browser_text">#2A241D</color>           <!-- primary ink -->
    <color name="browser_text_2">#574E42</color>         <!-- secondary ink, subtitles -->
    <color name="browser_hint">#8A7F6E</color>           <!-- placeholders, captions -->
    <color name="browser_faint">#B3A892</color>          <!-- mono metadata in URL path -->
    <color name="browser_icon">#3A322A</color>           <!-- nav icons -->

    <!-- Status -->
    <color name="browser_progress_track">#00000000</color>
    <color name="browser_danger">#B53219</color>
    <color name="browser_success">#2A6A3C</color>
</resources>
