<?xml version="1.0" encoding="utf-8"?>
<!--
  Welcome promise row — one card in the privacy promise list.
  Used 4× via <include> on page 2.

  Bind in WelcomeActivity:
    findViewById<TextView>(R.id.welcome_promise_1.findViewById(R.id.welcome_promise_title))
      .text = getString(R.string.welcome_promise_1_title)
    ...etc.

  Alternative is to inflate one-off per promise and pass title/body in
  code. The strings live in handoff/strings.welcome.xml as
  welcome_promise_<n>_title / _body.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_welcome_promise_card"
    android:gravity="top"
    android:orientation="horizontal"
    android:paddingStart="14dp"
    android:paddingTop="12dp"
    android:paddingEnd="14dp"
    android:paddingBottom="12dp">

    <FrameLayout
        android:layout_width="22dp"
        android:layout_height="22dp"
        android:layout_marginTop="1dp"
        android:background="@drawable/bg_welcome_check_chip">

        <ImageView
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:layout_gravity="center"
            android:contentDescription="@null"
            android:src="@drawable/ic_welcome_check"
            android:tint="@color/browser_on_accent" />
    </FrameLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/welcome_promise_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="serif"
            android:textColor="@color/browser_text"
            android:textSize="16sp"
            android:textStyle="italic"
            tools:text="History stays here" />

        <TextView
            android:id="@+id/welcome_promise_body"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:lineSpacingExtra="2dp"
            android:textColor="@color/browser_text_2"
            android:textSize="12.5sp"
            tools:text="We don't sync, upload, or share your browsing." />
    </LinearLayout>

</LinearLayout>
