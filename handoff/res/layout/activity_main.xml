<?xml version="1.0" encoding="utf-8"?>
<!--
  Effective Browser v10 — paper theme rebuild of activity_main.xml.

  ALL existing IDs and child ordering are preserved. MainActivity.kt
  does not need any code changes to compile against this file; the
  visual upgrade is delivered entirely via:
    1. Updated color tokens (res/values/colors.xml)
    2. Type system from values/styles.xml
    3. Two new drawables (bg_address_pill.xml, bg_tab_badge.xml)
    4. Spannable styling of address_bar host vs. path — set from
       MainActivity.onUrlChanged() using:
         val span = SpannableStringBuilder()
         span.append(host, StyleSpan(BOLD), 0)
         span.append(path).apply {
           setSpan(ForegroundColorSpan(browser_faint), host.length, length, 0)
           setSpan(TypefaceSpan("monospace"), 0, length, 0)
         }
         address_bar.setText(span, BufferType.SPANNABLE)
-->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/browser_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/browser_bg_solid"
    tools:context=".MainActivity">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/top_chrome"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/browser_bg_solid"
        app:elevation="0dp"
        app:liftOnScroll="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingTop="8dp"
            android:paddingEnd="12dp"
            android:paddingBottom="6dp"
            app:layout_scrollFlags="scroll">

            <!--
              v10: pill goes from cardCornerRadius+cardElevation to a
              drawable background (bg_address_pill.xml) which paints a
              1dp warm stroke and the surface fill. Removing the
              MaterialCardView trims one View from the hierarchy.
            -->
            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:background="@drawable/bg_address_pill">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="12dp"
                    android:paddingEnd="6dp">

                    <!--
                      Site favicon. Bind in MainActivity via
                      WebView.getFavicon() → security_indicator if SSL
                      is broken, else a real favicon. Tint is removed —
                      favicons paint full-color.
                    -->
                    <ImageView
                        android:id="@+id/security_indicator"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:contentDescription="@string/security_indicator_secure"
                        android:src="@drawable/ic_lock_24"
                        app:tint="@color/browser_hint" />

                    <!--
                      Address bar. v10 styling notes:
                      - fontFamily=monospace + textSize=13sp gives a
                        condensed feel that matches the prototype
                      - When the host/path spannable is applied (see
                        header comment), host renders bold and the path
                        renders in browser_faint. EditText respects
                        SpannableString on setText.
                    -->
                    <EditText
                        android:id="@+id/address_bar"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@android:color/transparent"
                        android:fontFamily="monospace"
                        android:gravity="center_vertical"
                        android:hint="@string/address_hint"
                        android:imeOptions="actionGo"
                        android:importantForAutofill="no"
                        android:inputType="textUri"
                        android:letterSpacing="-0.01"
                        android:maxLines="1"
                        android:paddingStart="10dp"
                        android:paddingEnd="6dp"
                        android:textColor="@color/browser_text"
                        android:textColorHint="@color/browser_hint"
                        android:textSize="13sp" />

                    <ImageButton
                        android:id="@+id/go_button"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="@string/go_button"
                        android:padding="8dp"
                        android:src="@drawable/ic_arrow_forward_24"
                        app:tint="@color/browser_accent" />
                </LinearLayout>
            </FrameLayout>

            <ImageButton
                android:id="@+id/refresh_button"
                android:layout_width="40dp"
                android:layout_height="44dp"
                android:layout_marginStart="4dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/refresh_button"
                android:padding="10dp"
                android:src="@drawable/ic_refresh_24"
                app:tint="@color/browser_text_2" />
        </LinearLayout>

        <!--
          Progress hairline. v10 inset 12dp on each side so it floats
          inside the chrome margin rather than running edge-to-edge —
          matches the prototype.
        -->
        <ProgressBar
            android:id="@+id/loading_progress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:max="100"
            android:progress="0"
            android:progressBackgroundTint="@android:color/transparent"
            android:progressTint="@color/browser_accent"
            android:visibility="gone"
            app:layout_scrollFlags="scroll" />

        <!-- Find-in-page (unchanged structure, restyled colors) -->
        <LinearLayout
            android:id="@+id/find_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/browser_surface_muted"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="14dp"
            android:paddingTop="6dp"
            android:paddingEnd="6dp"
            android:paddingBottom="6dp"
            android:visibility="gone">

            <EditText
                android:id="@+id/find_input"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:hint="@string/find_in_page_hint"
                android:imeOptions="actionSearch"
                android:importantForAutofill="no"
                android:inputType="text"
                android:maxLines="1"
                android:textColor="@color/browser_text"
                android:textColorHint="@color/browser_hint"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/find_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:textColor="@color/browser_hint"
                android:textSize="11sp"
                tools:text="2 / 14" />

            <ImageButton
                android:id="@+id/find_prev"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/find_previous"
                android:padding="10dp"
                android:src="@drawable/ic_chevron_up_24"
                app:tint="@color/browser_icon" />

            <ImageButton
                android:id="@+id/find_next"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/find_next"
                android:padding="10dp"
                android:src="@drawable/ic_chevron_down_24"
                app:tint="@color/browser_icon" />

            <ImageButton
                android:id="@+id/find_close"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/find_close"
                android:padding="10dp"
                android:src="@drawable/ic_close_24"
                app:tint="@color/browser_icon" />
        </LinearLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <!-- Tab host (unchanged — single-child contract preserved) -->
    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/web_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior" />

    <!--
      Bottom chrome.
      v10 changes:
      - caption gets an accent dot prefix (built in code: prepend
        a non-breaking bullet "● " with ForegroundColorSpan(accent))
      - nav row keeps all 5 ImageButton IDs but is wrapped in
        a container with a 1dp top hairline (border_stroke)
      - tab_count_text moves into a small badge drawable on the
        upper-right of the tabs icon
    -->
    <LinearLayout
        android:id="@+id/bottom_chrome"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@color/browser_bg_solid"
        android:orientation="vertical"
        app:layout_behavior="com.google.android.material.behavior.HideViewOnScrollBehavior">

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/browser_stroke" />

        <TextView
            android:id="@+id/browser_caption"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:gravity="center"
            android:letterSpacing="0.02"
            android:paddingStart="18dp"
            android:paddingTop="8dp"
            android:paddingEnd="18dp"
            android:paddingBottom="2dp"
            android:text="@string/browser_caption"
            android:textColor="@color/browser_hint"
            android:textSize="11sp"
            tools:text="● Search · DuckDuckGo" />

        <LinearLayout
            android:id="@+id/navigation_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingStart="4dp"
            android:paddingTop="2dp"
            android:paddingEnd="4dp"
            android:paddingBottom="4dp">

            <ImageButton
                android:id="@+id/bookmark_button"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/bookmark_button"
                android:padding="14dp"
                android:src="@drawable/ic_bookmark_outline_24"
                app:tint="@color/browser_icon" />

            <FrameLayout
                android:id="@+id/tabs_button"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:contentDescription="@string/tab_switcher_button"
                android:focusable="true">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:importantForAccessibility="no"
                    android:padding="14dp"
                    android:src="@drawable/ic_tabs_outline_24"
                    app:tint="@color/browser_icon" />

                <!--
                  Tab count badge. Drawable is a 6dp-radius
                  rectangle filled with browser_surface_muted in v10
                  (was floating on the icon center). It now sits at
                  top-end with a small inset.
                -->
                <TextView
                    android:id="@+id/tab_count_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="-2dp"
                    android:background="@drawable/bg_tab_badge"
                    android:fontFamily="monospace"
                    android:importantForAccessibility="no"
                    android:includeFontPadding="false"
                    android:paddingStart="4dp"
                    android:paddingEnd="4dp"
                    android:textColor="@color/browser_text"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    tools:text="3" />
            </FrameLayout>

            <ImageButton
                android:id="@+id/search_button"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/search_button"
                android:padding="14dp"
                android:src="@drawable/ic_search_24"
                app:tint="@color/browser_icon" />

            <ImageButton
                android:id="@+id/home_button"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/home_button"
                android:padding="14dp"
                android:src="@drawable/ic_home_outline_24"
                app:tint="@color/browser_icon" />

            <ImageButton
                android:id="@+id/menu_button"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/browser_menu"
                android:padding="14dp"
                android:src="@drawable/ic_more_vert_24"
                app:tint="@color/browser_icon" />
        </LinearLayout>
    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
