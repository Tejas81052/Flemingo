<?xml version="1.0" encoding="utf-8"?>
<!--
  Welcome header — logo + step dots row.
  <include>d at the top of pages 1 & 2. Page 3 uses the inverse variant.

  Step indicator state: WelcomeActivity must paint the active dot on
  every page change. See handoff/MainActivity.patch.kt → fun configureStepDots
  for the snippet. The 3 dots have IDs welcome_step_1 / _2 / _3.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal">

    <!-- Logo monogram -->
    <FrameLayout
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:background="@drawable/bg_welcome_logo_tile">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fontFamily="serif"
            android:gravity="center"
            android:includeFontPadding="false"
            android:text="E"
            android:textColor="@color/browser_on_accent"
            android:textSize="20sp"
            android:textStyle="italic" />
    </FrameLayout>

    <TextView
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:layout_weight="1"
        android:fontFamily="monospace"
        android:letterSpacing="0.14"
        android:text="@string/app_name"
        android:textAllCaps="true"
        android:textColor="@color/browser_hint"
        android:textSize="11sp" />

    <!-- Step dots: 3 children, active is the wider+filled one -->
    <View
        android:id="@+id/welcome_step_1"
        android:layout_width="28dp"
        android:layout_height="4dp"
        android:background="@drawable/bg_welcome_step_dot_active" />

    <View
        android:id="@+id/welcome_step_2"
        android:layout_width="14dp"
        android:layout_height="4dp"
        android:layout_marginStart="6dp"
        android:background="@drawable/bg_welcome_step_dot" />

    <View
        android:id="@+id/welcome_step_3"
        android:layout_width="14dp"
        android:layout_height="4dp"
        android:layout_marginStart="6dp"
        android:background="@drawable/bg_welcome_step_dot" />

</LinearLayout>
