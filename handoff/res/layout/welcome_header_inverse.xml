<?xml version="1.0" encoding="utf-8"?>
<!--
  Welcome header — inverted variant for page 3 (sits on the accent panel).
  Same view IDs as welcome_header.xml so configureStepDots() works
  identically on either page.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal">

    <FrameLayout
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:background="@drawable/bg_welcome_logo_tile_inverse">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fontFamily="serif"
            android:gravity="center"
            android:includeFontPadding="false"
            android:text="E"
            android:textColor="@color/browser_accent"
            android:textSize="20sp"
            android:textStyle="italic" />
    </FrameLayout>

    <TextView
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:layout_weight="1"
        android:alpha="0.85"
        android:fontFamily="monospace"
        android:letterSpacing="0.14"
        android:text="@string/app_name"
        android:textAllCaps="true"
        android:textColor="@color/browser_on_accent"
        android:textSize="11sp" />

    <!-- Step dots in cream — first two filled, last (active) extra wide -->
    <View
        android:id="@+id/welcome_step_1"
        android:layout_width="14dp"
        android:layout_height="4dp"
        android:background="@drawable/bg_welcome_step_dot_cream" />

    <View
        android:id="@+id/welcome_step_2"
        android:layout_width="14dp"
        android:layout_height="4dp"
        android:layout_marginStart="6dp"
        android:background="@drawable/bg_welcome_step_dot_cream" />

    <View
        android:id="@+id/welcome_step_3"
        android:layout_width="28dp"
        android:layout_height="4dp"
        android:layout_marginStart="6dp"
        android:background="@drawable/bg_welcome_step_dot_cream" />

</LinearLayout>
