<?xml version="1.0" encoding="utf-8"?>
<!--
  Address pill background. Replaces the MaterialCardView wrapper
  used in v9. 22dp corner radius matches the 44dp height (height/2).
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="@color/browser_surface" />
    <stroke
        android:width="1dp"
        android:color="@color/browser_stroke" />
    <corners android:radius="22dp" />
</shape>
